# Existing application settings
MONGODB_URI=mongodb://127.0.0.1:27017/manovaidya
PORT=5003

# Public site URL used when a blog does not have canonicalUrl
PUBLIC_SITE_URL=https://www.example.com

# Google Search Console property: URL-prefix (with trailing slash) or sc-domain property
GOOGLE_SEARCH_CONSOLE_SITE_URL=sc-domain:example.com

# Use ONE credential option. Add the service-account email as a Search Console property user.
GOOGLE_SERVICE_ACCOUNT_BASE64=base64_encoded_service_account_json
# GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}
# GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/service-account.json

# Gemini SEO review (server-side only; free tier available through Google AI Studio)
GEMINI_API_KEY=your_gemini_api_key
GEMINI_SEO_MODEL=gemini-3-flash-preview
GEMINI_SEO_FALLBACK_MODEL=gemini-3.1-flash-lite
